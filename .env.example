# Copy this file to .env and fill in your secrets. .env is gitignored.

# Hugging Face — accept MedGemma TOS at https://huggingface.co/google/medgemma-4b-it
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter — used for synthetic QA generation and LLM-as-judge eval
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# NVIDIA NIM (alternative to OpenRouter)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Kaggle — get from https://www.kaggle.com/settings (Create API Token)
KAGGLE_USERNAME=your_username
KAGGLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default LLM model identifiers
QA_SYNTH_MODEL=meta-llama/llama-3.3-70b-instruct
QA_JUDGE_MODEL=anthropic/claude-3.5-sonnet
